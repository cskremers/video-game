; Engine configuration file.
; Godot 4.3+ project — open with standard Godot editor.

config_version=5

[application]

config/name="Video Game"
config/description="2D high-fidelity co-op game for Steam (Windows + macOS)."
run/main_scene="res://scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
NetworkManager="*res://scripts/autoload/network_manager.gd"
SceneRouter="*res://scripts/autoload/scene_router.gd"
SteamService="*res://scripts/autoload/steam_service.gd"
CrashReporter="*res://scripts/autoload/crash_reporter.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Video Game"

